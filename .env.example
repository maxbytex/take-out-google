# Google OAuth2 Credentials
# Get these from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Redirect URI — must match exactly what you set in Google Cloud Console
# For local dev use: http://localhost:3000/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Express session secret (change this to a random string)
SESSION_SECRET=change_this_to_a_random_secret_string

# Port for the web server
PORT=3000

# Output directory for downloaded photos (relative path)
DOWNLOAD_DIR=./downloads
